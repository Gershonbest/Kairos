APP_NAME=Kairos Bookings API
APP_ENV=dev
APP_DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kairos
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_ORIGIN_REGEX=https://.*\.ngrok(-free)?\.app
PAYMENT_WEBHOOK_SECRET=change-me
# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Usually the same as PAYSTACK_SECRET_KEY (HMAC-SHA512 webhook verification).
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_PLATFORM_FEE_PERCENT=5.0
# Defaults to FRONTEND_BASE_URL when empty.
PAYSTACK_CALLBACK_BASE_URL=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PUBLIC_BOOKING_BASE_URL=http://localhost:5173/book
FRONTEND_BASE_URL=http://localhost:5173
# Brevo HTTP API key (xkeysib-...). SMTP keys (xsmtpsib-...) go in SMTP_PASSWORD.
BREVO_API_KEY=
# Google Gmail SMTP (account email + 16-char app password).
# Create at https://myaccount.google.com/apppasswords (2FA required).
GOOGLE_GMAIL_SENDER=
GOOGLE_GMAIL_APP_PASSWORD=
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Kairos Bookings
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=60
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
GOOGLE_CLIENT_ID=
# AWS S3 media uploads (required when APP_ENV=production).
# Prefer bucket policy for public read; leave S3_OBJECT_ACL empty unless the bucket allows ACLs.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=
S3_OBJECT_ACL=
# Local fallback when S3_BUCKET_NAME is empty (dev only).
LOCAL_UPLOAD_DIR=uploads
MEDIA_BASE_URL=http://localhost:8000/media
SUPER_ADMIN_EMAIL=admin@kairosbookings.com
SUPER_ADMIN_PASSWORD=Admin123!
SUPER_ADMIN_NAME=System Admin
TRIAL_DAYS=7
TRIAL_WARNING_DAYS=2
